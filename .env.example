# Django
SECRET_KEY=change-me-to-long-random-value
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
ENABLE_HTTPS_REDIRECT=False
TZ=Asia/Tashkent
BACKEND_URL=http://localhost:8000
SECURE_HSTS_SECONDS=31536000

# PostgreSQL default
DB_ENGINE=django.db.backends.postgresql
DB_NAME=unfold_boilerplate_db
DB_USER=unfold_user
DB_PASSWORD=unfold_password_change_me
DB_HOST=db
DB_PORT=5432
DB_CONN_MAX_AGE=60

# CORS / CSRF
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Redis / Channels
REDIS_URL=redis://redis:6379/0

# API throttling
DRF_THROTTLE_ANON=100/hour
DRF_THROTTLE_USER=1000/hour
DRF_THROTTLE_OTP=5/minute

# Upload limits
DATA_UPLOAD_MAX_MEMORY_SIZE=10485760
FILE_UPLOAD_MAX_MEMORY_SIZE=5242880

# JWT / OTP
JWT_ACCESS_TOKEN_MINUTES=30
JWT_REFRESH_TOKEN_DAYS=30
OTP_LENGTH=5
OTP_DEFAULT_CODE=11111
OTP_EXPIRY_SECONDS=120
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_DAILY_PER_PHONE=9999
OTP_MAX_VERIFY_ATTEMPTS=3
SMS_BACKEND=console

# RustFS S3-compatible media storage
USE_RUSTFS=True
FORCE_RUSTFS_IN_DEBUG=True
RUSTFS_ENDPOINT=localhost:9000
RUSTFS_INTERNAL_ENDPOINT=rustfs:9000
RUSTFS_USE_HTTPS=False
RUSTFS_INTERNAL_USE_HTTPS=False
RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=rustfsadmin-change-me
RUSTFS_BUCKET_NAME=unfold-boilerplate
RUSTFS_REGION=auto
RUSTFS_SERVER_DOMAINS=localhost

# Firebase optional
FIREBASE_CREDENTIALS_PATH=
FIREBASE_CREDENTIALS_JSON=
FIREBASE_CREDENTIALS_BASE64=
FCM_SERVER_KEY=
