msgid "This field is required."
msgstr "Bu maydon majburiy."

msgid "This field may not be blank."
msgstr "Bu maydon bo'sh bo'lishi mumkin emas."

msgid "This field may not be null."
msgstr "Bu maydon null bo'lishi mumkin emas."

msgid "Enter a valid value."
msgstr "To'g'ri qiymat kiriting."

msgid "Enter a valid email address."
msgstr "To'g'ri email manzil kiriting."

msgid "Ensure this field has no more than {max_length} characters."
msgstr "Bu maydonda {max_length} tadan ko'p belgi bo'lmasin."

msgid "Ensure this field has at least {min_length} characters."
msgstr "Bu maydonda kamida {min_length} ta belgi bo'lishi kerak."

msgid "A valid integer is required."
msgstr "Butun son kiritish kerak."

msgid "A valid number is required."
msgstr "To'g'ri son kiritish kerak."

msgid "Invalid value."
msgstr "Noto'g'ri qiymat."

msgid "Not found."
msgstr "Topilmadi."

msgid "Method \"{method}\" not allowed."
msgstr "\"{method}\" metodi ruxsat etilmagan."

msgid "Authentication credentials were not provided."
msgstr "Autentifikatsiya ma'lumotlari yuborilmagan."

msgid "You do not have permission to perform this action."
msgstr "Bu amalni bajarishga ruxsatingiz yo'q."

msgid "Invalid token."
msgstr "Token noto'g'ri."

msgid "Token is invalid or expired"
msgstr "Token noto'g'ri yoki muddati o'tgan"

msgid "Given token not valid for any token type"
msgstr "Berilgan token hech bir token turiga mos emas"

msgid "User is inactive"
msgstr "Foydalanuvchi faol emas"

msgid "No active account found with the given credentials"
msgstr "Berilgan ma'lumotlar bilan faol akkaunt topilmadi"

msgid "Request was throttled."
msgstr "So'rovlar soni cheklangan."

msgid "Request was throttled. Expected available in {wait} second."
msgstr "So'rovlar soni cheklangan. {wait} soniyadan keyin urinib ko'ring."

msgid "Request was throttled. Expected available in {wait} seconds."
msgstr "So'rovlar soni cheklangan. {wait} soniyadan keyin urinib ko'ring."

msgid "Incorrect type. Expected URL string, received {input_type}."
msgstr "Noto'g'ri tur. URL matni kutilgan, {input_type} olindi."

msgid "Invalid pk \"{pk_value}\" - object does not exist."
msgstr "Noto'g'ri pk \"{pk_value}\" — obyekt mavjud emas."

msgid "Invalid hyperlink - Object does not exist."
msgstr "Noto'g'ri havola — obyekt mavjud emas."

msgid "Invalid hyperlink - No URL match."
msgstr "Noto'g'ri havola — URL mos kelmadi."

msgid "Must be a valid UUID."
msgstr "To'g'ri UUID bo'lishi kerak."

msgid "Upload a valid image. The file you uploaded was either not an image or a corrupted image."
msgstr "To'g'ri rasm yuklang. Yuklangan fayl rasm emas yoki buzilgan."

msgid "The submitted data was not a file. Check the encoding type on the form."
msgstr "Yuborilgan ma'lumot fayl emas. Form encoding turini tekshiring."

msgid "No file was submitted."
msgstr "Fayl yuborilmadi."

msgid "The submitted file is empty."
msgstr "Yuborilgan fayl bo'sh."

msgid "Ensure this filename has at most {max_length} characters (it has {length})."
msgstr "Fayl nomi eng ko'pi {max_length} belgi bo'lishi kerak (hozir {length})."

msgid "Expected available in {wait} second."
msgstr "{wait} soniyadan keyin urinib ko'ring."

msgid "Expected available in {wait} seconds."
msgstr "{wait} soniyadan keyin urinib ko'ring."
