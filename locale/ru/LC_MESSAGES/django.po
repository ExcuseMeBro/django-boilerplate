msgid "PostgreSQL, MinIO media storage, JWT auth, OTP, DRF, Channels, and hardened admin defaults are ready."
msgstr "PostgreSQL, медиа-хранилище MinIO, JWT, OTP, DRF, Channels и защищенные настройки админ-панели готовы."

msgid "Open admin"
msgstr "Открыть админ-панель"

msgid "Health check"
msgstr "Проверка состояния"

msgid "This field is required."
msgstr "Это поле обязательно."

msgid "This field may not be blank."
msgstr "Это поле не может быть пустым."

msgid "This field may not be null."
msgstr "Это поле не может быть null."

msgid "Enter a valid value."
msgstr "Введите корректное значение."

msgid "Enter a valid email address."
msgstr "Введите корректный email адрес."

msgid "Ensure this field has no more than {max_length} characters."
msgstr "Убедитесь, что в поле не больше {max_length} символов."

msgid "Ensure this field has at least {min_length} characters."
msgstr "Убедитесь, что в поле минимум {min_length} символов."

msgid "A valid integer is required."
msgstr "Требуется целое число."

msgid "A valid number is required."
msgstr "Требуется корректное число."

msgid "Invalid value."
msgstr "Недопустимое значение."

msgid "Not found."
msgstr "Не найдено."

msgid "Method \"{method}\" not allowed."
msgstr "Метод \"{method}\" не разрешен."

msgid "Authentication credentials were not provided."
msgstr "Учетные данные не предоставлены."

msgid "You do not have permission to perform this action."
msgstr "У вас нет прав для выполнения этого действия."

msgid "Invalid token."
msgstr "Недействительный токен."

msgid "Token is invalid or expired"
msgstr "Токен недействителен или истек"

msgid "Given token not valid for any token type"
msgstr "Переданный токен не подходит ни к одному типу токена"

msgid "User is inactive"
msgstr "Пользователь неактивен"

msgid "No active account found with the given credentials"
msgstr "Активная учетная запись с указанными данными не найдена"

msgid "Request was throttled."
msgstr "Слишком много запросов."

msgid "Request was throttled. Expected available in {wait} second."
msgstr "Слишком много запросов. Повторите через {wait} секунду."

msgid "Request was throttled. Expected available in {wait} seconds."
msgstr "Слишком много запросов. Повторите через {wait} секунд."

msgid "Incorrect type. Expected URL string, received {input_type}."
msgstr "Неверный тип. Ожидалась строка URL, получено: {input_type}."

msgid "Invalid pk \"{pk_value}\" - object does not exist."
msgstr "Неверный pk \"{pk_value}\" — объект не существует."

msgid "Invalid hyperlink - Object does not exist."
msgstr "Неверная ссылка — объект не существует."

msgid "Invalid hyperlink - No URL match."
msgstr "Неверная ссылка — URL не найден."

msgid "Must be a valid UUID."
msgstr "Должен быть корректный UUID."

msgid "Upload a valid image. The file you uploaded was either not an image or a corrupted image."
msgstr "Загрузите корректное изображение. Файл не является изображением или поврежден."

msgid "The submitted data was not a file. Check the encoding type on the form."
msgstr "Отправленные данные не являются файлом. Проверьте тип кодирования формы."

msgid "No file was submitted."
msgstr "Файл не отправлен."

msgid "The submitted file is empty."
msgstr "Отправленный файл пуст."

msgid "Ensure this filename has at most {max_length} characters (it has {length})."
msgstr "Имя файла должно содержать не более {max_length} символов (сейчас {length})."

msgid "Expected available in {wait} second."
msgstr "Повторите через {wait} секунду."

msgid "Expected available in {wait} seconds."
msgstr "Повторите через {wait} секунд."
